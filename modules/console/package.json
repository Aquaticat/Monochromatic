{
  "name": "@monochromatic.dev/module-console",
  "type": "module",
  "module": "dist/final/index.js",
  "main": "dist/final/index.js",
  "typings": "dist/final/index.d.ts",
  "files": ["dist/final"],
  "scripts": {
    "// build": "tsc and esbuild can run 1st in parallel, but api-extractor depends on d.ts outputs from tsc, so it needs to run 2nd.",
    "build:tsc": "tsc",
    "build:esbuild": "esbuild src/index.ts --bundle --platform=node --charset=utf8 --format=esm --packages=external --target=node20 --drop:debugger --drop-labels=DEV,D --minify-whitespace --minify-syntax --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --preserve-symlinks --log-limit=0 --sourcemap=external",
    "build:api-extractor": "api-extractor run --local --verbose",
    "build:Types": "bun run build:tsc && bun run build:api-extractor",
    "build:Js": "bun run build:esbuild",
    "build": "bun run build:Types & bun run build:Js",
    "watch:api-extractor": "$TERMINAL chokidar \"dist/temp/tsc/**/*.d.ts\" --initial -c \"bun run build:api-extractor\"",
    "watch:tsc": "$TERMINAL tsc --watch",
    "watch:esbuild": "$TERMINAL esbuild src/index.ts --bundle --platform=node --charset=utf8 --format=esm --packages=external --target=node20 --drop:debugger --drop-labels=DEV,D --minify-whitespace --minify-syntax --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --preserve-symlinks --log-limit=0 --sourcemap=external --watch",
    "watch": "bun run watch:api-extractor & bun run watch:tsc & bun run watch:esbuild"
  },
  "devDependencies": {
    "typescript": ">=5.0.4",
    "@monochromatic.dev/tsconfig": "workspace:*",
    "@monochromatic.dev/config-api-extractor": "workspace:*",
    "esbuild": "*",
    "@microsoft/api-extractor": "*",
    "chokidar-cli": "*"
  },
  "dependencies": {},
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aquaticat/Monochromatic.git",
    "directory": "modules/console"
  }
}
