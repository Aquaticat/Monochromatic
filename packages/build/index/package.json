{
  "name": "@monochromatic.dev/build",
  "type": "module",
  "module": "dist/final/index.js",
  "main": "dist/final/index.js",
  "bin": { "monochromatic": "./dist/final/index.js" },
  "typings": "dist/final/index.d.ts",
  "files": ["dist/final"],
  "scripts": {
    "build:tsc": "tsc",
    "build:esbuild": "esbuild src/index.ts --bundle --platform=node --charset=utf8 --format=esm --packages=external --target=node20 --drop:debugger --drop-labels=DEV,D --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --log-limit=0 --sourcemap",
    "build:api-extractor": "api-extractor run --local --verbose",
    "build:Types": "pnpm run build:tsc && pnpm run build:api-extractor",
    "build:Js": "pnpm run build:esbuild",
    "build": "monochromatic build",
    "postbuild": "pnpm i",
    "watch:api-extractor": "$TERMINAL chokidar \"dist/temp/tsc/**/*.d.ts\" --initial -c \"pnpm run build:api-extractor\"",
    "watch:tsc": "$TERMINAL tsc --watch",
    "watch:esbuild": "$TERMINAL esbuild src/index.ts --bundle --platform=node --charset=utf8 --format=esm --packages=external --target=node20 --drop:debugger --drop-labels=DEV,D --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --log-limit=0 --sourcemap --watch",
    "watch": "pnpm run watch:api-extractor & pnpm run watch:tsc & pnpm run watch:esbuild"
  },
  "devDependencies": {
    "@biomejs/biome": ">=1.7",
    "@monochromatic.dev/build": "*",
    "@monochromatic.dev/config-api-extractor": "*",
    "@monochromatic.dev/config-typescript": "*",
    "chokidar-cli": "*",
    "esbuild": "*",
    "typescript": ">=5.4.5",
    "@types/node": ">=20.12.7",
    "vite": "*"
  },
  "dependencies": {
    "@microsoft/api-extractor": "*",
    "@mdx-js/esbuild": "*",
    "@mdx-js/vue": "*",
    "remark": "*",
    "remark-frontmatter": "*",
    "remark-mdx-frontmatter": "*",
    "yaml": "*",
    "remark-smartypants": "*",
    "remark-gfm": "*",
    "remark-github-beta-blockquote-admonitions": "*",
    "@hbsnow/rehype-sectionize": "*",
    "glob": "*",
    "to-vfile": ">=8.0.0",
    "lightningcss": ">=1.24.1",
    "@monochromatic.dev/esbuild-plugin-jsonc": "*",
    "@monochromatic.dev/esbuild-plugin-toml": "*",
    "@monochromatic.dev/esbuild-plugin-yaml": "*",
    "@monochromatic.dev/lightningcss-plugin-apply": "*",
    "@monochromatic.dev/lightningcss-plugin-custom-units": "*",
    "@monochromatic.dev/lightningcss-plugin-property-lookup": "*",
    "@monochromatic.dev/lightningcss-plugin-size": "*",
    "@monochromatic.dev/schema-theme-consts": "*",
    "@monochromatic.dev/module-resolve": "*",
    "@monochromatic.dev/module-console": "*",
    "@monochromatic.dev/module-fs-path": "*",
    "@monochromatic.dev/module-not-or-throw": "*",
    "@monochromatic.dev/module-langs": "*",
    "spdx-license-list": ">=6.9.0",
    "zod-opts": ">=0.1.8",
    "zx": ">=8",
    "zod": ">=3.22.4",
    "browserslist": ">=4.23.0",
    "esbuild-plugin-browserslist": ">=0.11.1",
    "esbuild-plugin-vue3": "*",
    "rambdax": ">=11.1.0",
    "postcss": ">=8.4.38",
    "cssnano": ">=6.1.2",
    "cssnano-preset-default": "*",
    "find-up": ">=7",
    "chrono-node": "*",
    "mdast-util-from-markdown": ">=2.0.0",
    "mdast-util-to-string": ">=4.0.0"
  },
  "peerDependencies": {
    "vue": ">=3.4.23",
    "@mdx-js/vue": ">=3.0.1",
    "to-vfile": ">=8.0.0",
    "vue-tsc": ">=2.0.13"
  },
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aquaticat/Monochromatic.git",
    "directory": "build/index"
  },
  "monochromatic": {
    "isEventualConsumer": true
  }
}
