{
  "name": "@monochromatic.dev/module-equals",
  "type": "module",
  "module": "dist/final/index.js",
  "main": "dist/final/index.js",
  "bin": "dist/final/bin.js",
  "typings": "dist/final/index.d.ts",
  "files": ["dist/final"],
  "scripts": {
    "build:tsc": "tsc",
    "build:esbuild": "esbuild src/index.ts --bundle --platform=node --charset=utf8 --format=esm --packages=external --target=node20 --drop:debugger --drop-labels=DEV,D --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --preserve-symlinks --log-limit=0 --sourcemap",
    "build:esbuild_bin": "esbuild src/bin.ts --bundle --platform=node --charset=utf8 --format=esm --preserve-symlinks --target=node20 --drop:debugger --drop-labels=DEV,D --define:process.env.NODE_ENV=\\\"production\\\" --minify-whitespace --minify-syntax --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --log-limit=0 --sourcemap=external",
    "build:api-extractor": "api-extractor run --local --verbose",
    "build:Types": "pnpm run build:tsc && pnpm run build:api-extractor",
    "build:Js": "pnpm run build:esbuild & pnpm run build:esbuild_bin",
    "build": "pnpm run build:Types & pnpm run build:Js",
    "watch:api-extractor": "$TERMINAL chokidar \"dist/temp/tsc/**/*.d.ts\" --initial -c \"pnpm run build:api-extractor\"",
    "watch:tsc": "$TERMINAL tsc --watch",
    "watch:esbuild": "$TERMINAL esbuild src/index.ts --bundle --platform=node --charset=utf8 --format=esm --packages=external --target=node20 --drop:debugger --drop-labels=DEV,D --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --preserve-symlinks --log-limit=0 --sourcemap --watch",
    "watch:esbuild_bin": "$TERMINAL esbuild src/bin.ts --bundle --platform=node --charset=utf8 --format=esm --preserve-symlinks --target=node20 --drop:debugger --drop-labels=DEV,D --define:process.env.NODE_ENV=\\\"production\\\" --minify-whitespace --minify-syntax --keep-names --outdir=dist/final/ --metafile=dist/temp/esbuild/meta.json --log-limit=0 --sourcemap=external --watch",
    "watch": "pnpm run watch:api-extractor & pnpm run watch:tsc & pnpm run watch:esbuild & pnpm run watch:esbuild_bin"
  },
  "peerDependencies": {
  },
  "dependencies": {
    "zod": "*",
    "rambdax": "*",
    "@monochromatic.dev/module-console": "*"
  },
  "devDependencies": {
    "@biomejs/biome": ">=1.6",
    "esbuild": ">=0.20",
    "typescript": ">=5.4",
    "@types/node": ">=20.12",
    "chokidar-cli": ">=3.0",
    "@microsoft/api-extractor":">=7.43",
    "@monochromatic.dev/config-api-extractor":"*",
    "@monochromatic.dev/config-typescript":"*"
  },
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aquaticat/Monochromatic.git",
    "directory": "modules/equals"
  }
}
