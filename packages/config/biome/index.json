{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "ignore": [
      "**/node_modules/**/*.*",
      "**/build/**/*.*",
      "**/dist/**/*.*",
      "**/.dist/**/*.*",
      "**/bak/**/*.*",
      "**/.astro/**/*.*"
    ],
    "include": [
      "**/*.js",
      "**/*.ts",
      "**/*.mjs",
      "**/*.mts",
      "**/*.cjs",
      "**/*.cts",
      "**/*.json",
      "**/*.jsonc"
    ]
  },
  "vcs": {
    "enabled": true,
    "useIgnoreFile": true,
    "clientKind": "git"
  },
  "linter": {
    "rules": {
      "recommended": true,
      "a11y": {
        "noAccessKey": "off",
        "noAutofocus": "off",
        "noSvgWithoutTitle": "off"
      },
      "complexity": {
        "noForEach": "off"
      },
      "correctness": {
        "noSetterReturn": "off",
        "noUnusedImports": "off"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      },
      "style": {
        "noArguments": "off",
        "noNonNullAssertion": "off",
        "useShorthandArrayType": "error",
        "useShorthandAssign": "error",
        "useSingleCaseStatement": "error",
        "noUnusedTemplateLiteral": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noExtraNonNullAssertion": "off",
        "noExplicitAny": "off"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 120,
    "attributePosition": "multiline"
  },
  "organizeImports": {
    "enabled": false
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "trailingComma": "all",
      "bracketSameLine": true
    },
    "globals": [
      "Astro"
    ]
  },
  "overrides": [
    {
      "include": [
        ".vscode/**",
        "**/api-extractor.json",
        "**/*.tsconfig.json",
        "**/tsconfig.*.json",
        "**/tsconfig.json",
        "**/devcontainer.json",
        "**/*.jsonc",
        "**/dprint.json",
        "**/dprint/index.json"
      ],
      "json": {
        "parser": {
          "allowComments": true,
          "allowTrailingCommas": true
        },
        "formatter": {
          "trailingCommas": "all"
        }
      }
    }
  ]
}