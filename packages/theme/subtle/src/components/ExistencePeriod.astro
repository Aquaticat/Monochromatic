---
import { langsPosts } from "./_globs.astro";

const years = Array.from(langsPosts.values()).flat().flatMap(post => [new Date(post.frontmatter.published).getFullYear(), new Date(post.frontmatter.updated).getFullYear()]);

const earliestYear = Math.min(...years);
const latestYear = Math.max(...years);
---

<span class="existence-period">
  <time datetime={earliestYear.toString()}>{earliestYear}</time>
  -
  <time datetime={latestYear.toString()}>{latestYear}</time>
</span>
