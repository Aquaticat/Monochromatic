---
import consts from '../temp/consts';
import { langsPosts, } from './_globs.astro';
import Post from './Post.astro';
const lang = Astro.currentLocale!;
const posts = Astro.props.posts || langsPosts.get(lang === consts.langs.defaultLang ? '' : lang,);
---

<ul class='Posts'>
  {posts.map((post,) => <Post {post}></Post>)}
</ul>
../temp/consts
